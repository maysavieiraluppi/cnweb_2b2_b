        "import math\n",
        "\n",
        "def eq2grau(a, b, c):\n",
        "   delta = b**2 - 4*a*c\n",
        "\n",
        "   if(delta < 0):\n",
        "     return 'equação sem solução'\n",
        "   else:\n",
        "      x1 = (-b + math.sqrt(delta)) /(2*a)\n",
        "      x2= (-b - math.sqrt(delta)) /(2*a)\n",
        "      return x1,  x2"
      ],
